							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "photo",
									"type": "file",
									"src": "",
									"description": "File foto profil (JPG/PNG, max 2MB)"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/api/users/2/photo",
