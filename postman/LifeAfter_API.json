{
	"info": {
		"_postman_id": "lifeafter-api-collection-v1",
		"name": "LifeAfter API",
		"description": "Koleksi endpoint REST API untuk proyek LifeAfter (Laravel 13 + Sanctum).\n\n**Setup:**\n1. Buat environment `LifeAfter Local`\n2. Set variable `base_url` = `http://localhost:8000`\n3. Login dulu → token tersimpan otomatis via Tests script\n\n**Akun Testing (Seeder):**\n- Admin: `admin@lifeafter.test` / `password`\n- Member: `member@lifeafter.test` / `password`",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Authentication",
			"description": "Endpoint untuk registrasi, login, logout, dan cek user aktif.",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"User Baru\",\n    \"email\": \"userbaru@test.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "register"]
						},
						"description": "Daftarkan user baru sebagai member. Status awal adalah `pending` — user belum bisa login sampai disetujui admin.\n\n**Expected:** 201 Created"
					},
					"response": [
						{
							"name": "201 Created — Registrasi berhasil",
							"originalRequest": {
								"method": "POST",
								"header": [
									{"key": "Accept", "value": "application/json"},
									{"key": "Content-Type", "value": "application/json"}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"name\": \"User Baru\",\n    \"email\": \"userbaru@test.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\"\n}"
								},
								"url": {"raw": "{{base_url}}/api/auth/register"}
							},
							"status": "Created",
							"code": 201,
							"_postman_previewlanguage": "json",
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n    \"status\": \"success\",\n    \"message\": \"Pendaftaran berhasil, menunggu persetujuan admin\",\n    \"data\": {\n        \"user\": {\n            \"id\": 3,\n            \"name\": \"User Baru\",\n            \"email\": \"userbaru@test.com\",\n            \"role\": \"member\",\n            \"status\": \"pending\"\n        }\n    }\n}"
						},
						{
							"name": "422 — Validasi gagal (email sudah terdaftar)",
							"originalRequest": {
								"method": "POST",
								"header": [{"key": "Accept", "value": "application/json"}],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"name\": \"Admin Angkatan\",\n    \"email\": \"admin@lifeafter.test\",\n    \"password\": \"password\",\n    \"password_confirmation\": \"password\"\n}"
								},
								"url": {"raw": "{{base_url}}/api/auth/register"}
							},
							"status": "Unprocessable Entity",
							"code": 422,
							"_postman_previewlanguage": "json",
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n    \"status\": \"error\",\n    \"message\": \"Validasi gagal\",\n    \"errors\": {\n        \"email\": [\"Email sudah terdaftar.\"]\n    }\n}"
						}
					]
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.status === 'success' && res.data && res.data.token) {",
									"    pm.collectionVariables.set('token', res.data.token);",
									"    console.log('✅ Token saved:', res.data.token);",
									"} else {",
									"    console.log('⚠️ Login gagal atau token tidak ada.');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"member@lifeafter.test\",\n    \"password\": \"password\"\n}",
							"options": {
								"raw": {"language": "json"}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "Login menggunakan email dan password. Token Sanctum akan otomatis tersimpan ke variable `token` via Tests script.\n\n**Akun member:** `member@lifeafter.test` / `password`\n**Akun admin:** `admin@lifeafter.test` / `password`"
					},
					"response": [
						{
							"name": "200 OK — Login berhasil (member)",
							"originalRequest": {
								"method": "POST",
								"header": [{"key": "Accept", "value": "application/json"}],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"email\": \"member@lifeafter.test\",\n    \"password\": \"password\"\n}"
								},
								"url": {"raw": "{{base_url}}/api/auth/login"}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n    \"status\": \"success\",\n    \"data\": {\n        \"token\": \"2|abc123xyz...\",\n        \"user\": {\n            \"id\": 2,\n            \"name\": \"Rafif Dummy\",\n            \"nickname\": null,\n            \"email\": \"member@lifeafter.test\",\n            \"role\": \"member\",\n            \"status\": \"active\",\n            \"city\": \"Bandung\",\n            \"job\": \"Software Engineer\",\n            \"company\": \"Tech Corp\",\n            \"bio\": null,\n            \"quote\": null,\n            \"born_date\": \"2000-05-15\",\n            \"lat\": \"-6.9175000\",\n            \"lng\": \"107.6191000\",\n            \"photo_url\": null,\n            \"social_links\": null,\n            \"created_at\": \"10 Apr 2026\"\n        }\n    }\n}"
						},
						{
							"name": "401 — Email atau password salah",
							"originalRequest": {
								"method": "POST",
								"header": [{"key": "Accept", "value": "application/json"}],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"email\": \"salah@test.com\",\n    \"password\": \"wrongpassword\"\n}"
								},
								"url": {"raw": "{{base_url}}/api/auth/login"}
							},
							"status": "Unauthorized",
							"code": 401,
							"_postman_previewlanguage": "json",
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n    \"status\": \"error\",\n    \"message\": \"Email atau password salah\"\n}"
						},
						{
							"name": "403 — Akun belum disetujui admin (pending)",
							"originalRequest": {
								"method": "POST",
								"header": [{"key": "Accept", "value": "application/json"}],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"email\": \"userbaru@test.com\",\n    \"password\": \"password123\"\n}"
								},
								"url": {"raw": "{{base_url}}/api/auth/login"}
							},
							"status": "Forbidden",
							"code": 403,
							"_postman_previewlanguage": "json",
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n    \"status\": \"error\",\n    \"message\": \"Akun kamu belum disetujui admin\"\n}"
						}
					]
				},
				{
					"name": "Get Current User (Me)",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/auth/me",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "me"]
						},
						"description": "Ambil data user yang sedang login berdasarkan token.\nToken diambil otomatis dari variable `{{token}}`.\n\n**Butuh:** Bearer token (login dulu)"
					},
					"response": [
						{
							"name": "200 OK — Data user aktif",
							"originalRequest": {
								"method": "GET",
								"header": [
									{"key": "Accept", "value": "application/json"},
									{"key": "Authorization", "value": "Bearer {{token}}"}
								],
								"url": {"raw": "{{base_url}}/api/auth/me"}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n    \"status\": \"success\",\n    \"data\": {\n        \"user\": {\n            \"id\": 2,\n            \"name\": \"Rafif Dummy\",\n            \"nickname\": null,\n            \"email\": \"member@lifeafter.test\",\n            \"role\": \"member\",\n            \"status\": \"active\",\n            \"city\": \"Bandung\",\n            \"job\": \"Software Engineer\",\n            \"company\": \"Tech Corp\",\n            \"born_date\": \"2000-05-15\",\n            \"lat\": \"-6.9175000\",\n            \"lng\": \"107.6191000\",\n            \"photo_url\": null,\n            \"social_links\": null,\n            \"created_at\": \"10 Apr 2026\"\n        }\n    }\n}"
						},
						{
							"name": "401 — Token tidak valid atau tidak ada",
							"originalRequest": {
								"method": "GET",
								"header": [{"key": "Accept", "value": "application/json"}],
								"url": {"raw": "{{base_url}}/api/auth/me"}
							},
							"status": "Unauthorized",
							"code": 401,
							"_postman_previewlanguage": "json",
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n    \"status\": \"error\",\n    \"message\": \"Unauthenticated. Token tidak valid atau tidak ada.\"\n}"
						}
					]
				},
				{
					"name": "Logout",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.status === 'success') {",
									"    pm.collectionVariables.set('token', '');",
									"    console.log('✅ Token cleared.');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"url": {
							"raw": "{{base_url}}/api/auth/logout",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "logout"]
						},
						"description": "Logout dan hapus token aktif dari database.\nSetelah logout, variable `token` otomatis dikosongkan via Tests script."
					},
					"response": [
						{
							"name": "200 OK — Logout berhasil",
							"originalRequest": {
								"method": "POST",
								"header": [
									{"key": "Accept", "value": "application/json"},
									{"key": "Authorization", "value": "Bearer {{token}}"}
								],
								"url": {"raw": "{{base_url}}/api/auth/logout"}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n    \"status\": \"success\",\n    \"message\": \"Logout berhasil\"\n}"
						}
					]
				}
			]
		},
		{
