{
  "info": {
    "name": "Lifeafter API — Bagian Ryuta",
    "_postman_id": "lifeafter-api-ryuta-2026",
    "description": "Postman Collection untuk endpoint bagian Ryuta:\nFeed (Post & Like), Komentar, Galeri, Event & RSVP, Notifikasi, Admin.\n\nBase URL: {{base_url}} = http://localhost:8000\nSemua request butuh header: Authorization: Bearer {{token}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "token",    "value": "YOUR_TOKEN_HERE",       "type": "string" }
  ],
  "item": [

    {
      "name": "Feed",
      "item": [
        {
          "name": "GET Semua Post",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/posts?category=karier&page=1",
              "host": ["{{base_url}}"],
              "path": ["api", "posts"],
              "query": [
                { "key": "category", "value": "karier", "description": "Filter: karier|pendidikan|keluarga|perjalanan|lainnya" },
                { "key": "page",     "value": "1" }
              ]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\"status\":\"success\",\"data\":[{\"id\":1,\"content\":\"Halo semua! Ini post pertama.\",\"photo_url\":null,\"category\":\"karier\",\"likes_count\":3,\"is_liked\":false,\"comments_count\":1,\"author\":{\"id\":1,\"name\":\"Admin Angkatan\",\"photo_url\":null},\"created_at\":\"10 Apr 2026, 10:00\"}],\"links\":{\"first\":\"http://localhost:8000/api/posts?page=1\",\"last\":\"http://localhost:8000/api/posts?page=1\",\"prev\":null,\"next\":null},\"meta\":{\"current_page\":1,\"last_page\":1,\"per_page\":15,\"total\":1}}"
